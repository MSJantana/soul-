    {
      "name": "Flow (passo a passo)",
      "item": [
        {
          "name": "01 Login (ADMIN) -> set accessToken",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@soulmais.local\",\n  \"password\": \"Admin@12345\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', json.accessToken);",
                  "pm.collectionVariables.set('refreshToken', json.refreshToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "02 List groups -> set groupId",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/groups"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.expect(json.groups).to.be.an('array');",
                  "",
                  "const g = json.groups[0];",
                  "pm.expect(g && g.id).to.be.a('string');",
                  "pm.collectionVariables.set('groupId', g.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "03 Periods current -> set periodKey (weekKey)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/periods/current"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.expect(json.weekKey).to.be.a('string');",
                  "pm.collectionVariables.set('periodKey', json.weekKey);"
                ]
              }
            }
          ]
        },
        {
          "name": "04 List activities -> set activityId (period=SEMANAL)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/activities"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.expect(json.activities).to.be.an('array');",
                  "",
                  "const list = json.activities || [];",
                  "const a = list.find((x) => x && (x.period === 'SEMANAL' || x.period === 'WEEK')) || list[0];",
                  "pm.expect(a && a.id).to.be.a('string');",
                  "pm.collectionVariables.set('activityId', a.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "05 Save completion (PENDENTE) - PUT /api/completions/by-group",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"groupId\": \"{{groupId}}\",\n  \"activityId\": \"{{activityId}}\",\n  \"periodKey\": \"{{periodKey}}\",\n  \"status\": \"PENDENTE\",\n  \"evidenceUrl\": \"https://example.com/comprovante\"\n}"
            },
            "url": "{{baseUrl}}/api/completions/by-group"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.expect(json.ok).to.eql(true);",
                  "pm.expect(json.completion).to.be.an('object');",
                  "pm.expect(json.completion.status).to.eql('PENDENTE');"
                ]
              }
            }
          ]
        },
        {
          "name": "06 Validate completion - PUT /api/completions/by-group/validate",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"groupId\": \"{{groupId}}\",\n  \"activityId\": \"{{activityId}}\",\n  \"periodKey\": \"{{periodKey}}\"\n}"
            },
            "url": "{{baseUrl}}/api/completions/by-group/validate"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.expect(json.ok).to.eql(true);",
                  "pm.expect(json.completion).to.be.an('object');",
                  "pm.expect(json.completion.status).to.eql('CONCLUIDA');",
                  "pm.expect(json.completion.isValidated).to.eql(true);"
                ]
              }
            }
          ]
        },
